# Local environments and credentials
/.venv/
/.env
/.env.*
!/.env.example

# Editor and OS state
/.vscode/
.DS_Store
Thumbs.db

# Upstream reference clone. Re-clone from:
# https://github.com/dxlabskku/TJS_Prediction.git
# The local clone also contains the authors' private final_df.csv; never commit it.
/TJS_Prediction/

# Python artifacts and tool caches
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.cache/

# Root research data. Keep this rule anchored so dashboard/public/data remains
# versioned with the dashboard source.
/data/
/data.zip

# Large or regeneratable binary artifacts outside /data
*.pth
*.pt
*.parquet
*.npz
*.npy
*.log

# Regeneratable prediction dumps; decision CSVs under results/ stay tracked.
/results/preds/
/results/phase2/preds/
